#!/usr/bin/env python3
"""Mock graphify CLI for integration tests.

Mirrors the real graphifyy CLI surface that worca depends on:
  graphify --version         → prints "graphify 0.8.16"
  graphify update <path>     → re-extracts the code graph, writing stub
                               artifacts to the output dir. Structural by
                               default; "full" when a provider key is present
                               in the env (GEMINI_API_KEY / GOOGLE_API_KEY /
                               OPENAI_API_KEY), matching the real tool's
                               key-driven semantic pass.

Output dir resolution (highest first):
  GRAPHIFY_OUT           — the real graphify env var (per-commit cache snapshot)
  MOCK_GRAPHIFY_OUT_DIR  — test override
  graphify-out           — default

Env vars:
  MOCK_GRAPHIFY_FAIL     — if "1", exit with code 1 (simulate build failure)
  MOCK_GRAPHIFY_LOG      — if set, append invocation args to this file (JSONL)
"""
import json
import os
import sys
from pathlib import Path

_PROVIDER_KEYS = ("GEMINI_API_KEY", "GOOGLE_API_KEY", "OPENAI_API_KEY")


def _log_invocation():
    log_path = os.environ.get("MOCK_GRAPHIFY_LOG")
    if not log_path:
        return
    entry = {"argv": sys.argv, "cwd": os.getcwd()}
    with open(log_path, "a") as f:
        f.write(json.dumps(entry) + "\n")


def main():
    _log_invocation()

    if os.environ.get("MOCK_GRAPHIFY_FAIL") == "1":
        print("error: mock build failure", file=sys.stderr)
        sys.exit(1)

    if "--version" in sys.argv:
        print("graphify 0.8.16")
        sys.exit(0)

    if "update" in sys.argv:
        out_dir = (
            os.environ.get("GRAPHIFY_OUT")
            or os.environ.get("MOCK_GRAPHIFY_OUT_DIR")
            or "graphify-out"
        )
        out_path = Path(out_dir)
        out_path.mkdir(parents=True, exist_ok=True)

        # Real `update` is code-only unless a provider key is present in env.
        mode = (
            "full" if any(os.environ.get(k) for k in _PROVIDER_KEYS) else "structural"
        )
        report = (
            f"# Graph Report (mock)\n\n"
            f"Mode: {mode}\n"
            f"Nodes: 42\n"
            f"Edges: 108\n"
            f"Communities: 5\n"
        )
        (out_path / "GRAPH_REPORT.md").write_text(report)
        (out_path / "graph.json").write_text('{"nodes": 42, "edges": 108}\n')
        (out_path / "graph.html").write_text("<html><body>mock graph</body></html>\n")
        print(f"Code graph updated ({mode} mode)")
        sys.exit(0)

    print(f"error: unknown command: {sys.argv[1:]}", file=sys.stderr)
    sys.exit(1)


if __name__ == "__main__":
    main()
