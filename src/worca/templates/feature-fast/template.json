{
  "id": "feature-fast",
  "name": "Feature Development (Fast)",
  "description": "Full pipeline for substantial features without a pre-drafted plan. Plan is drafted and reviewed in-line — review can edit directly, shortcutting the review-revise loop. Learn stage on, higher retry limits.",
  "builtin": true,
  "created_at": "2026-05-29T00:00:00Z",
  "tags": [
    "full-pipeline",
    "plan-review",
    "plan-edit",
    "learn"
  ],
  "config": {
    "stages": {
      "plan": {
        "agent": "planner",
        "enabled": true
      },
      "coordinate": {
        "agent": "coordinator",
        "enabled": true
      },
      "implement": {
        "agent": "implementer",
        "enabled": true
      },
      "test": {
        "agent": "tester",
        "enabled": true
      },
      "review": {
        "agent": "reviewer",
        "enabled": true
      },
      "pr": {
        "agent": "guardian",
        "enabled": true
      },
      "learn": {
        "agent": "learner",
        "enabled": true
      },
      "plan_review": {
        "agent": "plan_reviewer",
        "enabled": true,
        "mode": "review_and_edit"
      }
    },
    "loops": {
      "implement_test": 10,
      "pr_changes": 5,
      "restart_planning": 3,
      "plan_review": 3
    },
    "effort": {
      "auto_mode": "adaptive",
      "auto_cap": "xhigh"
    },
    "agents": {
      "planner": {
        "model": "opus",
        "max_turns": 100,
        "effort": "xhigh"
      },
      "coordinator": {
        "model": "opus",
        "max_turns": 300,
        "effort": "high"
      },
      "implementer": {
        "model": "sonnet",
        "max_turns": 300
      },
      "tester": {
        "model": "sonnet",
        "max_turns": 100
      },
      "reviewer": {
        "model": "opus",
        "max_turns": 50,
        "effort": "high"
      },
      "guardian": {
        "model": "opus",
        "max_turns": 50,
        "effort": "high"
      },
      "learner": {
        "model": "opus",
        "max_turns": 50
      },
      "plan_reviewer": {
        "model": "opus",
        "max_turns": 50,
        "effort": "high"
      }
    },
    "circuit_breaker": {
      "enabled": true,
      "max_consecutive_failures": 3,
      "transient_retry_count": 3,
      "transient_retry_backoff_seconds": [
        10,
        30,
        90
      ]
    },
    "milestones": {
      "plan_approval": true,
      "pr_approval": false,
      "deploy_approval": false
    },
    "governance": {
      "test_gate_strikes": 2,
      "plan_review_enforce": "auto"
    }
  }
}
