{
  "id": "quick-fix",
  "name": "Quick Fix",
  "description": "Minimal pipeline for trivial changes. Opus plans, sonnet implements. No test, review, or PR \u2014 changes left on branch for manual commit.",
  "builtin": true,
  "created_at": "2026-03-10T00:00:00Z",
  "tags": [
    "minimal",
    "fast",
    "no-review"
  ],
  "config": {
    "stages": {
      "plan": {
        "agent": "planner",
        "enabled": true
      },
      "coordinate": {
        "agent": "coordinator",
        "enabled": true
      },
      "implement": {
        "agent": "implementer",
        "enabled": true
      },
      "test": {
        "agent": "tester",
        "enabled": false
      },
      "review": {
        "agent": "reviewer",
        "enabled": false
      },
      "pr": {
        "agent": "guardian",
        "enabled": false
      },
      "learn": {
        "agent": "learner",
        "enabled": false
      },
      "plan_review": {
        "agent": "plan_reviewer",
        "enabled": false,
        "mode": "review"
      }
    },
    "effort": {
      "auto_mode": "disabled",
      "auto_cap": "xhigh"
    },
    "agents": {
      "planner": {
        "model": "opus",
        "max_turns": 50,
        "effort": "medium"
      },
      "coordinator": {
        "model": "opus",
        "max_turns": 50,
        "effort": "low"
      },
      "implementer": {
        "model": "sonnet",
        "max_turns": 100,
        "effort": "low"
      },
      "tester": {
        "model": "sonnet",
        "max_turns": 100
      },
      "reviewer": {
        "model": "opus",
        "max_turns": 50,
        "effort": "high"
      },
      "guardian": {
        "model": "opus",
        "max_turns": 50,
        "effort": "high"
      },
      "learner": {
        "model": "opus",
        "max_turns": 50
      },
      "plan_reviewer": {
        "model": "opus",
        "max_turns": 50,
        "effort": "high"
      }
    },
    "loops": {
      "implement_test": 0,
      "pr_changes": 5,
      "restart_planning": 2,
      "plan_review": 2
    },
    "milestones": {
      "plan_approval": false,
      "pr_approval": false,
      "deploy_approval": false
    },
    "circuit_breaker": {
      "enabled": true,
      "max_consecutive_failures": 1,
      "transient_retry_count": 3,
      "transient_retry_backoff_seconds": [
        10,
        30,
        90
      ]
    }
  }
}
