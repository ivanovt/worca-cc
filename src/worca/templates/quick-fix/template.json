{
  "id": "quick-fix",
  "name": "Quick Fix",
  "description": "Minimal pipeline for trivial changes. Haiku plans, sonnet coordinates and implements, no test or review. Budget-capped at $5.",
  "builtin": true,
  "created_at": "2026-03-10T00:00:00Z",
  "tags": ["minimal", "fast", "no-review"],
  "config": {
    "stages": {
      "test":   { "enabled": false },
      "review": { "enabled": false }
    },
    "agents": {
      "planner":     { "model": "haiku", "max_turns": 15 },
      "coordinator": { "model": "sonnet", "max_turns": 15 },
      "implementer": { "model": "sonnet", "max_turns": 100 }
    },
    "loops": {
      "implement_test": 0
    },
    "milestones": {
      "plan_approval": false,
      "pr_approval": false,
      "deploy_approval": false
    },
    "circuit_breaker": { "max_consecutive_failures": 1 }
  }
}
