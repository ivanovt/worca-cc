{
  "id": "quick-fix",
  "name": "Quick Fix",
  "description": "Minimal pipeline for trivial changes. Opus plans, sonnet implements. No test, review, or PR — changes left on branch for manual commit.",
  "builtin": true,
  "created_at": "2026-03-10T00:00:00Z",
  "tags": ["minimal", "fast", "no-review"],
  "config": {
    "stages": {
      "test":   { "enabled": false },
      "review": { "enabled": false },
      "pr":     { "enabled": false }
    },
    "effort": {
      "auto_mode": "disabled"
    },
    "agents": {
      "planner":     { "model": "opus", "max_turns": 50, "effort": "medium" },
      "coordinator": { "model": "opus", "max_turns": 50, "effort": "low" },
      "implementer": { "model": "sonnet", "max_turns": 100, "effort": "low" }
    },
    "loops": {
      "implement_test": 0
    },
    "milestones": {
      "plan_approval": false,
      "pr_approval": false,
      "deploy_approval": false
    },
    "circuit_breaker": { "max_consecutive_failures": 1 }
  }
}
