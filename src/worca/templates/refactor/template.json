{
  "id": "refactor",
  "name": "Refactor",
  "description": "Full pipeline without PR, all agents on Opus. Reviewer enforces behavioral preservation. Branch left for manual review.",
  "builtin": true,
  "created_at": "2026-03-10T00:00:00Z",
  "tags": ["no-pr", "extra-test"],
  "config": {
    "stages": {
      "pr": { "enabled": false },
      "plan_review": { "enabled": true }
    },
    "agents": {
      "planner":     { "model": "opus", "max_turns": 100 },
      "coordinator": { "model": "opus", "max_turns": 300 },
      "implementer": { "model": "opus", "max_turns": 300 },
      "tester":      { "model": "opus", "max_turns": 100 },
      "reviewer":    { "model": "opus", "max_turns": 50 }
    },
    "loops": {
      "implement_test": 10,
      "restart_planning": 2
    },
    "milestones": {
      "plan_approval": true,
      "pr_approval": false,
      "deploy_approval": false
    }
  }
}
