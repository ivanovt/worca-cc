{
  "id": "feature-minor",
  "name": "Minor Feature",
  "description": "Lean autonomous pipeline for well-scoped features. Full implement/test/review/PR but no plan review, no learn, no approval gates. Good fit for PR-revision work where scope is already constrained by review comments.",
  "builtin": true,
  "created_at": "2026-05-27T00:00:00Z",
  "tags": [
    "feature",
    "minor",
    "no-gate"
  ],
  "config": {
    "effort": {
      "auto_mode": "adaptive",
      "auto_cap": "high"
    },
    "loops": {
      "implement_test": 8,
      "pr_changes": 4,
      "restart_planning": 2,
      "plan_review": 2
    },
    "milestones": {
      "plan_approval": false,
      "pr_approval": false,
      "deploy_approval": false
    },
    "agents": {
      "planner": {
        "model": "opus",
        "max_turns": 100,
        "effort": "xhigh"
      },
      "coordinator": {
        "model": "opus",
        "max_turns": 300,
        "effort": "high"
      },
      "implementer": {
        "model": "sonnet",
        "max_turns": 300
      },
      "tester": {
        "model": "sonnet",
        "max_turns": 100
      },
      "reviewer": {
        "model": "opus",
        "max_turns": 50,
        "effort": "high"
      },
      "guardian": {
        "model": "opus",
        "max_turns": 50,
        "effort": "high"
      },
      "learner": {
        "model": "opus",
        "max_turns": 50
      },
      "plan_reviewer": {
        "model": "opus",
        "max_turns": 50,
        "effort": "high"
      }
    },
    "circuit_breaker": {
      "enabled": true,
      "max_consecutive_failures": 3,
      "transient_retry_count": 3,
      "transient_retry_backoff_seconds": [
        10,
        30,
        90
      ]
    },
    "stages": {
      "plan": {
        "agent": "planner",
        "enabled": true
      },
      "coordinate": {
        "agent": "coordinator",
        "enabled": true
      },
      "implement": {
        "agent": "implementer",
        "enabled": true
      },
      "test": {
        "agent": "tester",
        "enabled": true
      },
      "review": {
        "agent": "reviewer",
        "enabled": true
      },
      "pr": {
        "agent": "guardian",
        "enabled": true
      },
      "learn": {
        "agent": "learner",
        "enabled": false
      },
      "plan_review": {
        "agent": "plan_reviewer",
        "enabled": false,
        "mode": "review"
      }
    },
    "governance": {
      "test_gate_strikes": 2,
      "plan_review_enforce": "auto"
    }
  }
}
