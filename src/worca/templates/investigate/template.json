      "enabled": true,
      "max_consecutive_failures": 3,
      "transient_retry_count": 3,
      "transient_retry_backoff_seconds": [
        10,
        30,
        90
      ]
    },
    "governance": {
      "test_gate_strikes": 2,
      "plan_review_enforce": "auto"
    }
  }
