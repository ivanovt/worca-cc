{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workspace",
  "type": "object",
  "required": ["name", "repos"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Workspace display name used in UI, PR annotations, and branch templates"
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "path", "depends_on"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Repo identifier referenced in depends_on lists"
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Relative path from workspace root to the repo directory"
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Repo names that must complete before this repo starts"
          }
        }
      }
    },
    "integration_test": {
      "type": "object",
      "required": ["command", "working_dir"],
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1,
          "description": "Shell command for cross-repo integration tests"
        },
        "working_dir": {
          "type": "string",
          "description": "Working directory relative to workspace root"
        }
      }
    },
    "umbrella_repo": {
      "type": "string",
      "minLength": 1,
      "description": "GitHub org/repo for the umbrella issue linking all workspace PRs"
    }
  }
}
