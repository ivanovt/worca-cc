{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewOutput",
  "type": "object",
  "required": ["outcome"],
  "properties": {
    "outcome": { "type": "string", "enum": ["approve", "request_changes", "reject", "restart_planning"] },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "severity": { "type": "string", "enum": ["critical", "major", "minor", "suggestion"] },
          "description": { "type": "string" }
        }
      }
    },
    "iteration_count": { "type": "integer", "minimum": 1 }
  }
}
