---
// The single-run state machine, rendered via the shared FlowDiagram component.
// States and transitions are the authoritative pipeline model from
// docs/state-action-matrix.md. Blue = forward transition, amber = resume
// (the recovery back-edges). Built with the /worca-docs-diagram skill.
import FlowDiagram from './FlowDiagram.astro';

const nodes = [
	{ id: 'pending', label: 'Pending', tip: 'Run created but not yet started.', cx: 380, cy: 44 },
	{ id: 'running', label: 'Running', tip: 'Actively executing stages — the hub. From here a run can pause, stop, fail, or finish.', cx: 380, cy: 175 },
	{ id: 'paused', label: 'Paused', tip: 'Cleanly checkpointed by you at a stage boundary. Resume continues exactly where it left off — no data lost.', cx: 120, cy: 175 },
	{ id: 'failed', label: 'Failed', tip: 'Unrecoverable error, loop exhaustion, circuit breaker, or a crash. Terminal — but resumable with --resume.', cx: 640, cy: 175 },
	{ id: 'interrupted', label: 'Interrupted', tip: 'You stopped it (control file, signal, or webhook abort). Terminal for events, but resumable because the stop was intentional.', cx: 120, cy: 320 },
	{ id: 'cancelled', label: 'Cancelled', tip: 'Force-cancelled from the UI. Terminal and NOT resumable.', cx: 640, cy: 320 },
	{ id: 'completed', label: 'Completed', tip: 'All stages finished and a pull request exists. Terminal.', cx: 380, cy: 360 },
];

const edges = [
	// forward (blue)
	{ from: 'pending', to: 'running' },
	{ from: 'running', to: 'completed' },
	{ path: 'M285,167 H215', kind: 'forward', label: 'pause', labelX: 250, labelY: 156 },
	{ path: 'M475,167 H545', kind: 'forward', label: 'error', labelX: 510, labelY: 156 },
	{ path: 'M320,195 V322 H215', kind: 'forward', label: 'stop', labelX: 340, labelY: 250 },
	{ path: 'M460,195 V320 H545', kind: 'forward', label: 'cancel', labelX: 493, labelY: 250 },
	// resume — recovery (amber)
	{ path: 'M215,183 H285', kind: 'return', label: 'resume', labelX: 250, labelY: 198 },
	{ path: 'M545,183 H475', kind: 'return', label: 'resume', labelX: 510, labelY: 198 },
	{ path: 'M215,300 H300 V195', kind: 'return', label: 'resume', labelX: 252, labelY: 286 },
];

const ariaLabel =
	'worca run state machine. Forward: Pending to Running; Running to Completed; Running can pause to Paused, stop to Interrupted, error to Failed, or cancel to Cancelled. Resume (recovery) returns Paused, Interrupted, and Failed back to Running. Completed and Cancelled are terminal.';
---

<FlowDiagram nodes={nodes} edges={edges} width={760} height={405} ariaLabel={ariaLabel} />
