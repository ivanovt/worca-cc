---
// The 9-stage worca pipeline, rendered via the shared FlowDiagram component.
// This file is just the *data* — the style lives in FlowDiagram.astro so every
// diagram on the site stays visually consistent. Add new diagrams with the
// /worca-docs-diagram skill.
import FlowDiagram from './FlowDiagram.astro';

const CX = 260;

const stages = [
	{ name: 'Preflight', purpose: 'Validates the environment', tip: 'Language-agnostic environment checks — git state, dependencies, config — run before any tokens are spent, so broken setups fail fast.', y: 36 },
	{ name: 'Planner', purpose: 'Explores code, writes the plan', tip: 'Explores the codebase and writes the implementation plan (MASTER_PLAN.md) the run follows.', y: 112 },
	{ name: 'Plan Reviewer', purpose: 'Audits the plan (optional)', tip: 'Audits the plan for gaps, feasibility, and fit; loops back to the Planner on critical issues. Off by default.', y: 188, optional: true },
	{ name: 'Coordinator', purpose: 'Splits the plan into tasks (aka beads)', tip: 'Decomposes the plan into tracked tasks — beads — with dependencies and parallel groups.', y: 264 },
	{ name: 'Implementer', purpose: 'Builds each task, test-first', tip: 'Implements each task test-first, then commits and closes it. Independent tasks can run in parallel.', y: 340 },
	{ name: 'Tester', purpose: 'Runs tests, collects proof', tip: 'Runs the test suite, verifies coverage, and collects proof. Loops back to the Implementer when tests fail.', y: 416 },
	{ name: 'Reviewer', purpose: 'Reviews code and conventions', tip: 'Reviews changes for bugs, quality, and conventions; sends work back to the Implementer when changes are needed.', y: 492 },
	{ name: 'Guardian', purpose: 'Commits, opens the PR', tip: 'The only agent allowed to commit. Verifies the test proof, commits, and opens the pull request.', y: 568 },
	{ name: 'Learner', purpose: 'Retrospective (optional)', tip: 'Produces a post-run retrospective with ranked, copyable suggestions. Off by default.', y: 644, optional: true },
];

const nodes = stages.map((s) => ({
	id: s.name,
	label: s.name,
	sublabel: s.purpose,
	tip: s.tip,
	cx: CX,
	cy: s.y,
	optional: s.optional,
}));

const forward = stages.slice(0, -1).map((s, i) => ({ from: s.name, to: stages[i + 1].name }));

const returns = [
	{ path: 'M165,188 H128 V112 H165', kind: 'return', label: 'critical issues', labelX: 128, labelY: 150 },
	{ path: 'M165,416 H116 V346 H165', kind: 'return', label: 'tests fail', labelX: 116, labelY: 372 },
	{ path: 'M165,492 H92 V334 H165', kind: 'return', label: 'changes requested', labelX: 92, labelY: 452 },
];

const ariaLabel =
	'worca pipeline. Forward: Preflight, Planner, Plan Reviewer (optional), Coordinator, Implementer, Tester, Reviewer, Guardian, Learner (optional). Loopbacks: Plan Reviewer back to Planner on critical issues; Tester back to Implementer when tests fail; Reviewer back to Implementer when changes are requested.';
---

<FlowDiagram nodes={nodes} edges={[...forward, ...returns]} width={640} height={700} ariaLabel={ariaLabel} />
