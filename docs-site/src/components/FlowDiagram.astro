---
// Canonical worca flow-diagram renderer. Data-driven so every diagram on the
// docs site (pipeline, state graph, DAG) shares one visual language: blue
// forward edges, amber return/transition edges, animated marching-ants flow,
// hover/focus tooltips, light+dark theming, and reduced-motion support.
//
// Author new diagrams with the /worca-docs-diagram skill — do NOT fork the
// styles into another component; change them here so all diagrams stay in sync.
//
// Props:
//   nodes:   { id, label, sublabel?, tip?, cx, cy, w?, h?, optional? }[]
//   edges:   { from?, to?, path?, kind?: 'forward'|'return',
//              label?, labelX?, labelY? }[]
//            - `path` (explicit SVG path) wins; otherwise a straight line is
//              drawn from `from`'s bottom-centre to `to`'s top-centre.
//            - kind 'return' renders amber (loopbacks / transitions).
//   width/height: SVG viewBox extent. ariaLabel: full text description.
const DEFAULT_W = 190;
const DEFAULT_H = 40;

const { nodes = [], edges = [], width = 640, height = 700, ariaLabel = 'Flow diagram' } = Astro.props;

const byId = Object.fromEntries(nodes.map((n) => [n.id, n]));
const w = (n) => n?.w ?? DEFAULT_W;
const h = (n) => n?.h ?? DEFAULT_H;
---

<div class="fd-flow">
	<svg viewBox={`0 0 ${width} ${height}`} role="img" aria-label={ariaLabel}>
		<defs>
			<marker id="fd-arrow" markerWidth="8" markerHeight="8" refX="5.5" refY="3" orient="auto"><path class="fd-arrowhead-forward" d="M0,0 L6,3 L0,6 Z" /></marker>
			<marker id="fd-arrowR" markerWidth="8" markerHeight="8" refX="5.5" refY="3" orient="auto"><path class="fd-arrowhead-return" d="M0,0 L6,3 L0,6 Z" /></marker>
		</defs>

		{edges.map((e) => {
			const isReturn = e.kind === 'return';
			const cls = isReturn ? 'fd-edge fd-return' : 'fd-edge fd-forward';
			const marker = isReturn ? 'url(#fd-arrowR)' : 'url(#fd-arrow)';
			if (e.path) {
				return <path class={cls} d={e.path} marker-end={marker} />;
			}
			const a = byId[e.from];
			const b = byId[e.to];
			return (
				<line class={cls} x1={a.cx} y1={a.cy + h(a) / 2} x2={b.cx} y2={b.cy - h(b) / 2} marker-end={marker} />
			);
		})}

		{edges.filter((e) => e.label).map((e) => (
			<text class="fd-edge-label" x={e.labelX} y={e.labelY}>{e.label}</text>
		))}

		{nodes.map((n) => (
			<g class:list={['fd-node', { optional: n.optional }]} tabindex="0" data-name={n.label} data-tip={n.tip ?? n.sublabel ?? ''} aria-label={n.tip || n.sublabel ? `${n.label}: ${n.tip ?? n.sublabel}` : n.label}>
				<rect class="fd-rect" x={n.cx - w(n) / 2} y={n.cy - h(n) / 2} width={w(n)} height={h(n)} rx="10" />
				<text class="fd-name" x={n.cx} y={n.cy} text-anchor="middle" dominant-baseline="central">{n.label}</text>
				{n.sublabel && (
					<text class="fd-sublabel" x={n.cx + w(n) / 2 + 15} y={n.cy} dominant-baseline="central">{n.sublabel}</text>
				)}
			</g>
		))}
	</svg>
	<div class="fd-tip" role="tooltip" aria-hidden="true"></div>
</div>

<style is:global>
	.fd-flow {
		--fd-flow: var(--sl-color-accent);
		--fd-text: var(--sl-color-white);
		--fd-muted: var(--sl-color-gray-3);
		--fd-optional: var(--sl-color-gray-4);
		--fd-return: #d97706;
		--fd-return-label: #b45309;
		position: relative;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 14px;
		padding: 24px 20px;
		margin: 1.5rem 0;
		background: var(--sl-color-bg);
	}
	[data-theme='dark'] .fd-flow {
		--fd-return: #fbbf24;
		--fd-return-label: #fcd34d;
	}
	.fd-flow svg { width: 100%; height: auto; display: block; }

	.fd-node { cursor: pointer; }
	.fd-rect { fill: var(--sl-color-bg); stroke: var(--fd-flow); stroke-width: 1.3; transition: fill .15s ease, stroke-width .15s ease; }
	.fd-node.optional .fd-rect { stroke: var(--fd-optional); stroke-dasharray: 4 3; }
	.fd-name { fill: var(--fd-text); font-size: 13.5px; font-weight: 600; }
	.fd-node.optional .fd-name { fill: var(--fd-muted); font-weight: 500; }
	.fd-sublabel { fill: var(--fd-muted); font-size: 11.5px; transition: fill .15s ease; }

	.fd-node:hover, .fd-node:focus-visible { outline: none; filter: drop-shadow(0 3px 8px rgba(59, 130, 246, 0.22)); }
	.fd-node:hover .fd-rect, .fd-node:focus-visible .fd-rect { fill: color-mix(in srgb, var(--fd-flow) 9%, var(--sl-color-bg)); stroke-width: 2.4; }
	.fd-node:hover .fd-name, .fd-node:focus-visible .fd-name { fill: var(--fd-flow); }
	.fd-node:hover .fd-sublabel, .fd-node:focus-visible .fd-sublabel { fill: var(--fd-text); }

	.fd-forward { fill: none; stroke: var(--fd-flow); stroke-width: 1.8; stroke-dasharray: 6 5; animation: fdFlowForward 1.3s linear infinite; }
	.fd-return { fill: none; stroke: var(--fd-return); stroke-width: 1.5; stroke-dasharray: 5 4; stroke-linejoin: round; animation: fdFlowReturn 1.7s linear infinite; }
	.fd-arrowhead-forward { fill: var(--fd-flow); }
	.fd-arrowhead-return { fill: var(--fd-return); }
	.fd-edge-label { fill: var(--fd-return-label); font-size: 10.5px; font-weight: 600; text-anchor: middle; paint-order: stroke; stroke: var(--sl-color-bg); stroke-width: 3.5px; stroke-linejoin: round; }

	@keyframes fdFlowForward { to { stroke-dashoffset: -22; } }
	@keyframes fdFlowReturn { to { stroke-dashoffset: -18; } }
	@media (prefers-reduced-motion: reduce) { .fd-forward, .fd-return { animation: none; } }

	.fd-tip { position: fixed; z-index: 60; max-width: 280px; background: #0f172a; color: #e2e8f0; border: 1px solid #1e293b; border-radius: 10px; padding: 10px 12px; font-size: 12.5px; line-height: 1.5; box-shadow: 0 10px 28px rgba(2, 6, 23, 0.28); pointer-events: none; opacity: 0; transform: translateY(4px); transition: opacity .12s ease, transform .12s ease; }
	[data-theme='dark'] .fd-tip { background: #334155; border-color: #475569; color: #f1f5f9; }
	.fd-tip.show { opacity: 1; transform: translateY(0); }
	.fd-tip .fd-tip-name { display: block; font-weight: 700; color: #fff; margin-bottom: 3px; font-size: 13px; }
</style>

<script>
	for (const root of document.querySelectorAll('.fd-flow')) {
		const tip = root.querySelector('.fd-tip');
		if (!tip) continue;
		const tipName = document.createElement('span');
		tipName.className = 'fd-tip-name';
		const tipDesc = document.createTextNode('');
		tip.append(tipName, tipDesc);

		const position = (x, y) => {
			const r = tip.getBoundingClientRect();
			let nx = x;
			let ny = y;
			if (nx + r.width > window.innerWidth - 8) nx = x - r.width - 28;
			if (ny + r.height > window.innerHeight - 8) ny = window.innerHeight - r.height - 8;
			if (ny < 8) ny = 8;
			tip.style.left = `${nx}px`;
			tip.style.top = `${ny}px`;
		};
		const show = (node) => {
			tipName.textContent = node.dataset.name || '';
			tipDesc.textContent = node.dataset.tip || '';
			tip.classList.add('show');
		};
		const hide = () => tip.classList.remove('show');

		for (const node of root.querySelectorAll('.fd-node')) {
			node.addEventListener('mouseenter', () => show(node));
			node.addEventListener('mousemove', (e) => position(e.clientX + 14, e.clientY + 14));
			node.addEventListener('mouseleave', hide);
			node.addEventListener('focus', () => {
				show(node);
				const b = node.getBoundingClientRect();
				position(b.right + 12, b.top);
			});
			node.addEventListener('blur', hide);
			node.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') node.blur();
			});
		}
	}
</script>
