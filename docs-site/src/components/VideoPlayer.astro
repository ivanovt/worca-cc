---
/**
 * VideoPlayer — HTML5 video embed styled to match the worca brand.
 *
 * Uses native browser controls (play/pause, seek, volume, fullscreen,
 * speed, picture-in-picture, captions toggle). No JS dependency. The
 * MP4 is served from /videos/ — Cloudflare's edge cache handles
 * delivery.
 *
 * Props:
 *   src       relative URL to the .mp4 (e.g. "/videos/01-…/.mp4")
 *   poster    relative URL to the .jpg poster (shown before play)
 *   captions  relative URL to the .vtt subtitle file
 *   title     bold caption shown below the video
 *   subtitle  smaller caption next to the title
 *   duration  e.g. "2:55" — shown right-aligned next to the title
 */

interface Props {
  src: string;
  poster?: string;
  captions?: string;
  title: string;
  subtitle?: string;
  duration?: string;
}

const { src, poster, captions, title, subtitle, duration } = Astro.props;
---

<figure class="video-player">
  <video
    controls
    playsinline
    preload="metadata"
    poster={poster}
  >
    <source src={src} type="video/mp4" />
    {captions ? (
      <track
        kind="captions"
        src={captions}
        srclang="en"
        label="English"
        default
      />
    ) : null}
    <p>
      Your browser does not support embedded video.
      <a href={src}>Download the video</a> instead.
    </p>
  </video>

  <figcaption class="video-caption">
    <div class="video-caption-text">
      <span class="video-caption-title">{title}</span>
      {subtitle ? <span class="video-caption-subtitle">{subtitle}</span> : null}
    </div>
    {duration ? <span class="video-caption-duration">{duration}</span> : null}
  </figcaption>
</figure>

<style>
  .video-player {
    margin: 2rem 0 2.5rem;
    /* Override Starlight's default figure margins on small screens. */
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .video-player video {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: block;
    background: #050a14;
    border-radius: 8px;
    border: 1px solid var(--sl-color-gray-5, #333);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }

  .video-caption {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 0.25rem;
  }

  .video-caption-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .video-caption-title {
    font-size: var(--sl-text-base);
    font-weight: 600;
    color: var(--sl-color-white);
    line-height: 1.3;
  }

  .video-caption-subtitle {
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    line-height: 1.4;
  }

  .video-caption-duration {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
    font-weight: 500;
    flex-shrink: 0;
    /* Subtle accent — matches the worca mint */
    color: #00e5a0;
  }
</style>
