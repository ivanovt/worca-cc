---
/**
 * VideoPlayer — HTML5 video embed styled to match the worca brand.
 *
 * Caption block (title + subtitle + duration badge) renders ABOVE the
 * video so the viewer knows what they're about to watch before pressing
 * play. Uses native browser controls underneath (fullscreen, speed,
 * captions toggle, picture-in-picture). No JS dependency. MP4 is served
 * from /videos/ — Cloudflare's edge cache handles delivery.
 *
 * Props:
 *   src       relative URL to the .mp4 (e.g. "/videos/01-…/.mp4")
 *   poster    relative URL to the .jpg poster (shown before play)
 *   captions  relative URL to the .vtt subtitle file
 *   title     bold caption shown above the video
 *   subtitle  1–2 sentence description shown under the title
 *   duration  e.g. "2:55" — rendered as a badge on the right of the title
 */

interface Props {
  src: string;
  poster?: string;
  captions?: string;
  title: string;
  subtitle?: string;
  duration?: string;
}

const { src, poster, captions, title, subtitle, duration } = Astro.props;
---

<figure class="video-player">
  <figcaption class="video-caption">
    <div class="video-caption-header">
      <span class="video-caption-title">{title}</span>
      {duration ? <span class="video-caption-duration">{duration}</span> : null}
    </div>
    {subtitle ? <p class="video-caption-subtitle">{subtitle}</p> : null}
  </figcaption>

  <video
    controls
    playsinline
    preload="metadata"
    poster={poster}
  >
    <source src={src} type="video/mp4" />
    {captions ? (
      <track
        kind="captions"
        src={captions}
        srclang="en"
        label="English"
        default
      />
    ) : null}
    <p>
      Your browser does not support embedded video.
      <a href={src}>Download the video</a> instead.
    </p>
  </video>
</figure>

<style>
  .video-player {
    margin: 2rem 0 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .video-caption {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0 0.1rem;
  }

  .video-caption-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .video-caption-title {
    font-size: var(--sl-text-h4, 1.25rem);
    font-weight: 700;
    color: var(--sl-color-white);
    line-height: 1.2;
    min-width: 0;
  }

  .video-caption-subtitle {
    font-size: var(--sl-text-base);
    color: var(--sl-color-gray-2);
    line-height: 1.5;
    margin: 0;
  }

  /* Duration as a pill badge, mirroring Starlight's <Badge variant="tip"> */
  .video-caption-duration {
    flex-shrink: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #00e5a0;
    background: rgba(0, 229, 160, 0.10);
    border: 1px solid rgba(0, 229, 160, 0.35);
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
    line-height: 1.4;
    white-space: nowrap;
  }

  .video-player video {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: block;
    background: #050a14;
    border-radius: 8px;
    border: 1px solid var(--sl-color-gray-5, #333);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }
</style>
