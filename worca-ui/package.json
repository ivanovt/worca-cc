{
  "name": "@worca/ui",
  "version": "0.7.0",
  "description": "Pipeline monitoring UI for worca-cc",
  "license": "MIT",
  "author": "Sinisha Djukic",
  "repository": {
    "type": "git",
    "url": "https://github.com/SinishaDjukic/worca-cc.git",
    "directory": "worca-ui"
  },
  "keywords": [
    "worca",
    "pipeline",
    "monitoring",
    "dashboard",
    "ai-agents",
    "autonomous-coding"
  ],
  "type": "module",
  "bin": {
    "worca-ui": "./bin/worca-ui.js"
  },
  "files": [
    "bin/worca-ui.js",
    "server/*.js",
    "!server/*.test.js",
    "!server/test/",
    "app/favicon-*.svg",
    "app/index.html",
    "app/main.bundle.js",
    "app/main.bundle.js.map",
    "app/styles.css",
    "app/vendor/",
    "app/protocol.js",
    "app/utils/stage-order.js",
    "scripts/build-frontend.js"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node bin/worca-ui.js start",
    "stop": "node bin/worca-ui.js stop",
    "restart": "node bin/worca-ui.js restart",
    "build": "node scripts/build-frontend.js",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "playwright test",
    "test:browser:ui": "playwright test --ui",
    "lint": "biome check",
    "lint:fix": "biome check --write"
  },
  "dependencies": {
    "@shoelace-style/shoelace": "^2.20.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "lit-html": "^3.3.1",
    "lucide": "^0.577.0",
    "marked": "^17.0.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.27.1",
    "jsdom": "^29.0.1",
    "vitest": "^4.0.15"
  }
}
