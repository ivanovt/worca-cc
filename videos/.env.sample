# Copy to .env.local (gitignored) and fill in your ElevenLabs API key.
#
# The voice id and model are hardcoded in scripts/generate-voiceover.ts
# so every run produces audio in the brand voice. The API key is the
# only secret the build needs.
#
# Usage after .env.local is in place:
#   npm run voiceover
#   npm run build:videos
#
# Get a key at https://elevenlabs.io/app/settings/api-keys

ELEVENLABS_API_KEY=sk_...
