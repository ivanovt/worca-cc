# Copy to .env (gitignored) and fill in real values, or pass these inline:
#   ELEVENLABS_API_KEY=… ELEVENLABS_VOICE_ID=… npm run voiceover

# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...

# https://elevenlabs.io/app/voice-library — copy the Voice ID from the panel
ELEVENLABS_VOICE_ID=...

# Defaults to eleven_multilingual_v2 if unset.
# Alternates: eleven_turbo_v2_5 (faster), eleven_v3 (newer/alpha)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
